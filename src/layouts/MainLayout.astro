---
import "../styles/global.css";
import NavBar from "../components/NavBar";

const { title } = Astro.props;
const pageTitle = title ? `${title} · Amy Liu` : "Amy Liu";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
    </head>
    <body
        class="grid h-screen w-screen grid-cols-[1fr_auto] grid-rows-[auto_1fr] overflow-hidden"
    >
        <!-- signature -->
        <header class="top-0 z-30 col-span-2 flex h-20 w-screen items-center">
            <a
                href="/"
                class="text-wanderer-300 font-signature transition-default-100 relative left-4 z-20 scale-y-90 text-[2.5rem] font-extrabold hover:scale-[105%]"
            >
                Amy Liu
            </a>

            <button
                id="header_navbar-button"
                aria-label="Toggle navigation"
                class="drop-shadow-button transition-default-300 bg-wanderer-shadow text-wanderer-highlight pointer-events-auto relative right-4 my-auto mr-0 ml-auto cursor-pointer rounded-2xl p-2 active:translate-y-[4px]"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M4 6 h16 M4 12 h16 M4 18 h16"></path>
                </svg>
            </button>
        </header>

        <main class="transition-default-300 no-scrollbar overflow-y-scroll">
            <slot />
        </main>
        <NavBar client:load />
    </body>
</html>

<script>
    window.addEventListener("DOMContentLoaded", () => {
        const button = document.getElementById("header_navbar-button");

        if (button) {
            button.addEventListener("click", () => {
                console.log("clicked");
                window.dispatchEvent(new Event("toggle-navbar"));
            });
        }
    });
</script>
